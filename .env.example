# ============================================
# Renaiss Pulse — Environment Variables
# ============================================
# Copy this file to .env and fill in values.
# NEVER commit .env — only .env.example.
#
# Run `npm run wallet:setup` to generate
# WALLET_ENCRYPTED_SEED and WALLET_PASSWORD automatically.

# --- Server ---
PORT=3001

# ─── WDK: Wallet Seed (AES-256-GCM encrypted) ───────────────────────────────
#
# Generated by: npm run wallet:setup
# The setup script produces an encrypted ciphertext using wdk-utils encrypt()
# (AES-256-GCM + scrypt). The raw mnemonic is printed once and never stored.
# Both vars must be set — there is no plaintext fallback.
WALLET_ENCRYPTED_SEED=
WALLET_PASSWORD=

# ─── WDK: Tron Network ────────────────────────────────────────────────────────
#
# Tron node URL
# Shasta testnet (default): https://api.shasta.trongrid.io
# Nile testnet:             https://api.nileex.io
# Mainnet:                  https://api.trongrid.io
TRON_NODE_URL=https://api.shasta.trongrid.io
TRON_SOLIDITY_URL=https://api.shasta.trongrid.io
TRON_EVENT_URL=https://api.shasta.trongrid.io

# Tron chain ID
# Shasta testnet: 2494104990
# Mainnet:        728126428
TRON_CHAIN_ID=2494104990

# USDt (TRC-20) contract address
# Shasta testnet: TG3XXyExBkPp9nzdajDZsozEu4BkaSJozs
# Mainnet:        TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRON_USDT_CONTRACT=TG3XXyExBkPp9nzdajDZsozEu4BkaSJozs

# Recipient T-address for "spend" intents (required for spend actions)
SPEND_RECIPIENT=

# ─── WDK: Per-category Spend Limits (in whole USDt) ─────────────────────────
SPEND_LIMIT_TICKETS=500
SPEND_LIMIT_FEES=300
SPEND_LIMIT_TRAVEL=1000
SPEND_LIMIT_MERCH=200
SPEND_LIMIT_OTHER=50

# ─── QVAC (On-Device LLM) ────────────────────────────────────────────────────
# Model is auto-downloaded and cached by @qvac/sdk — no path config needed.
# Set QVAC_LOG=1 to enable verbose LLM inference logs.
QVAC_LOG=
