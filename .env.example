# ============================================
# Renaiss Pulse — Environment Variables
# ============================================
# Copy this file to .env and fill in values.
# NEVER commit .env — only .env.example.

# --- WDK (Wallet Development Kit) ---
# Self-custodial: keys are managed locally by the wallet module.
WDK_ENVIRONMENT=testnet
WDK_CHAIN=ethereum

# --- QVAC (On-Device LLM) ---
QVAC_MODEL_PATH=

# --- App ---
EXPO_PUBLIC_API_URL=
