{
  "name": "renaiss-pulse",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "web"
  ],
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev:backend": "node --env-file=.env --import tsx/esm src/server.ts",
    "dev:web": "npm run dev --workspace=web",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:web\"",
    "test:qvac": "node test-qvac.mjs",
    "wallet:setup": "node scripts/wallet-setup.mjs"
  },
  "dependencies": {
    "@qvac/sdk": "^0.14.0",
    "@tetherto/wdk": "^1.0.0-beta.14",
    "@tetherto/wdk-utils": "^1.0.0-beta.9",
    "@tetherto/wdk-wallet-tron": "^1.0.0-beta.8",
    "express": "^4.18.2"
  },
  "peerDependencies": {
    "bare-rpc": "^0.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "concurrently": "^8.2.2",
    "tsx": "^4.15.0",
    "typescript": "~5.5.4"
  }
}
